APP_NAME="QRMeets"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# PostgreSQL connection
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=qr_event_platform
DB_USERNAME=postgres
DB_PASSWORD=

# No cache/session tables are shipped by this app, so keep these on
# drivers that don't require extra migrations. Queue does have its own
# migrated tables (jobs/failed_jobs/job_batches) - registration-confirmation
# and reminder emails are queued so they don't block the request. Run
# `php artisan queue:work` (or set up a supervisor/systemd unit in
# production) - nothing processes queued jobs without a worker running.
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# CORS / Sanctum - frontend runs on Vite's default dev port.
# SANCTUM_STATEFUL_DOMAINS is unused (we use bearer-token auth via
# createToken(), not Sanctum's SPA cookie flow) but documented here
# in case that flow is adopted later.
SANCTUM_STATEFUL_DOMAINS=localhost:5173
FRONTEND_URL=http://localhost:5173

# Gemini API (server-side only - never exposed to the frontend bundle).
# Powers the event-wizard "Generate description" button and the organizer
# feedback-summary feature (see App\Services\Gemini). Get a key at
# https://aistudio.google.com/apikey - both features return a clean 503
# instead of crashing if this is left blank.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# 'log' writes emails to storage/logs/laravel.log instead of sending them -
# fine for local dev, but nothing reaches a real inbox. For production, use
# Resend's HTTP API (not SMTP - see below for why):
#   MAIL_MAILER=resend
#   RESEND_API_KEY=re_your_api_key
# MAIL_FROM_ADDRESS below must be on a domain verified in your Resend account.
MAIL_MAILER=log
RESEND_API_KEY=

# SMTP is also supported (any provider - Mailgun, SES, Postmark, Gmail, your
# own server - works the same way, only host/port/username/password change),
# but confirmed unreliable on Railway specifically: connecting to Resend's
# own SMTP endpoint (port 465 or 587) timed out in production even with
# correct credentials - PaaS hosts commonly block/throttle outbound SMTP
# ports to stop spam from ephemeral containers. Prefer the HTTP API above if
# your provider offers one; fall back to SMTP only if it doesn't.
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.mailgun.org
#   MAIL_PORT=587
#   MAIL_USERNAME=postmaster@yourdomain.mailgun.org
#   MAIL_PASSWORD=your-mailgun-smtp-password
# Port 587 auto-negotiates STARTTLS; for implicit TLS on port 465 also set
# MAIL_SCHEME=smtps.
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Payment screenshot storage (the "public" disk in config/filesystems.php).
# Left blank/local, screenshots write to local disk - fine for one persistent
# server, but they won't survive a redeploy on most hosting. Set these to
# move to any S3-compatible provider (Cloudflare R2, AWS S3, DigitalOcean
# Spaces) - R2 in particular has no egress fees:
#   FILESYSTEM_PUBLIC_DRIVER=s3
#   FILESYSTEM_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev   (R2's public bucket URL, or a custom domain mapped to it)
#   AWS_ACCESS_KEY_ID=your-r2-access-key-id
#   AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key
#   AWS_DEFAULT_REGION=auto
#   AWS_BUCKET=your-bucket-name
#   AWS_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
FILESYSTEM_PUBLIC_DRIVER=local
FILESYSTEM_PUBLIC_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
