# Laravel API base URL (see Backend/.env.example)
VITE_API_URL=http://localhost:8000/api

# Optional. If unset, event location pickers/maps fall back gracefully to
# plain text inputs and a free no-key Google Maps iframe embed — the app
# works with no setup. Get a key from the Google Cloud Console (enable the
# "Maps JavaScript API" and "Places API") to enable the interactive map.
VITE_GOOGLE_MAPS_API_KEY=
